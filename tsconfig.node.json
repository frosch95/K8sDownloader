{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist-types",
    "allowImportingTsExtensions": true,
    "isolatedModules": true
  },
  "include": ["vite.config.ts", "electron/**/*.ts", "src/utils/**/*.ts", "src/shared/**/*.ts", "src/services/**/*.ts", "src/types/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/**/*.spec.ts", "src/**/*.spec.tsx"]
}
